{
  "name": "vscode-folder-explorer",
  "displayName": "Folder Explorer",
  "description": "Explore a folder in the editor area",
  "version": "2.0.1",
  "publisher": "huanent",
  "icon": "resources/logo.png",
  "repository": {
    "url": "https://github.com/huanent/vscode-folder-explorer.git",
    "type": "github"
  },
  "license": "MIT",
  "homepage": "https://github.com/huanent/vscode-folder-explorer",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
  "customEditors": [
    {
    "viewType": "folderExplorer.editor",
    "displayName": "Folder Explorer",
    "selector": [
      {
      "filenamePattern": "*.folder-explorer"
      }
    ],
    "priority": "option"
    }
  ],
    "commands": [
      {
        "command": "folderExplorer.open",
        "title": "Open in Folder Explorer"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "folderExplorer.open",
          "when": "explorerResourceIsFolder",
          "group": "navigation@999"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "vscode-test",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@types/yauzl": "^3.4.0",
    "@types/yazl": "^3.3.1",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "yauzl": "^3.4.0",
    "yazl": "^3.3.1"
  }
}
