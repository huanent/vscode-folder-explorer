{
  "name": "vscode-folder-explorer",
  "displayName": "Folder Explorer",
  "description": "Explore folders in the VS Code editor area",
  "version": "1.0.0",
  "publisher": "huanent",
  "icon": "resources/logo.png",
  "repository": {
    "url": "https://github.com/huanent/vscode-folder-explorer.git",
    "type": "github"
  },
  "license": "MIT",
  "homepage": "https://github.com/huanent/vscode-folder-explorer",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "folderExplorer.open",
        "title": "Open in Folder Explorer"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "folderExplorer.open",
          "when": "explorerResourceIsFolder",
          "group": "navigation@999"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.4.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45"
  }
}
